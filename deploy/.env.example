# Copy to .env and adjust. Used by: docker compose --env-file .env up -d

# Image tag to run: "latest" tracks main, or pin a release like "v0.2.0".
WARD_TAG=latest

# Contact email for managed (Let's Encrypt) certificates. Optional — you can also
# set it later in the UI (Settings → TLS). Required for real ACME issuance.
WARD_ACME_EMAIL=

# Database. Default (unset) is a SQLite file on the ward_db volume. To use Postgres
# instead, bring the stack up with `--profile postgres` and uncomment both lines:
# WARD_DB=postgres://ward:CHANGE_ME@postgres:5432/ward?sslmode=disable
# POSTGRES_PASSWORD=CHANGE_ME

# CrowdSec. Set a bouncer API key to enable the whole CrowdSec path, then bring the
# stack up with `--profile crowdsec` and flip the toggle in Ward → Settings. The one
# key registers the ward-caddy bouncer AND lets Ward read decisions. Generate with:
#   openssl rand -hex 32
# Leave unset to run without CrowdSec.
# CROWDSEC_BOUNCER_KEY=CHANGE_ME
